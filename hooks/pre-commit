#!/bin/bash

# Pre-commit script for Python projects
# Runs Black, isort, and Flake8 on staged Python files
VENV=.venv


# Get staged Python files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$')

if [ -z "$STAGED_FILES" ]; then
    echo "✅ No Python files to check."
    exit 0
fi

echo "📁 Staged Python files:"
echo "$STAGED_FILES"

# Function to check if command exists
check_command() {
    if ! command -v "$1" &> /dev/null; then
        echo "❌ $1 is not installed. Install with: pip install $1"
        exit 1
    fi
}

# Check for required tools
source $VENV/bin/activate
check_command black
check_command isort
check_command flake8


ERRORS=0

# 1. Run isort (import sorting)
# echo "📦 Running isort..."
isort_output=$(isort --profile black -q $STAGED_FILES 2>&1)
isort_exit=$?
if [ $isort_exit -ne 0 ]; then
    echo "❌ isort failed:"
    echo "$isort_output"
    ERRORS=1
else
    echo "✅ isort passed"
fi

# 2. Run Black (code formatting)
# echo "🎨 Running Black..."
black_output=$(black -q $STAGED_FILES 2>&1)
black_exit=$?
if [ $black_exit -ne 0 ]; then
    echo "❌ Black failed:"
    echo "$black_output"
    ERRORS=1
else
    echo "✅ Black passed"
fi

# 3. Run Flake8 (linting)
# echo "🔍 Running Flake8..."
flake8_output=$(flake8 $STAGED_FILES 2>&1)
flake8_exit=$?
if [ $flake8_exit -ne 0 ]; then
    echo "❌ Flake8 failed:"
    echo "$flake8_output"
    ERRORS=1
else
    echo "✅ Flake8 passed"
fi

# Stage any auto-fixed files
git add $STAGED_FILES

if [ $ERRORS -ne 0 ]; then
    echo "❌ Pre-commit checks failed. Please fix the issues above."
    exit 1
else
    exit 0
fi

deactivate